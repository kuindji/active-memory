{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleDetection": "force",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": true
    },
    "include": ["src", "tests", "tests-integration", "eslint.config.ts", "memory-domain.config.ts"]
}
